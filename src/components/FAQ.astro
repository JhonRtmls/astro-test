---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// FAQ Schema for AI Search Readiness (Generated Server-Side for GEO)
const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [1, 2, 3, 4].map(i => ({
        "@type": "Question",
        "name": t(`faq.q${i}` as any),
        "acceptedAnswer": {
            "@type": "Answer",
            "text": t(`faq.a${i}` as any)
        }
    }))
};
---

<section class="section faq-section" id="faq">
    <div class="container">
        <div class="faq-grid">
            <!-- Columna Izquierda: Imagen (Optimización GEO: Authoritative Visual) -->
            <div class="faq-image-side reveal">
                <div class="faq-image-container">
                    <img src="/astro-test/img/work-3.webp" alt="Gestoo MICE & Logistics Experts in Patagonia" loading="lazy" />
                    <div class="image-accent-box"></div>
                </div>
            </div>

            <!-- Columna Derecha: Contenido -->
            <div class="faq-content-side">
                <div class="section-header reveal">
                    <span class="tag">{t('faq.tag')}</span>
                    <h2 class="section-title">{t('faq.title')} <em>{t('faq.title_accent')}</em></h2>
                </div>

                <div class="faq-accordion reveal">
                    {[1, 2, 3, 4].map((i) => (
                        <div class="faq-item">
                            <button class="faq-trigger" aria-expanded="false" id={`faq-btn-${i}`}>
                                <span>{t(`faq.q${i}` as any)}</span>
                                <span class="faq-icon"></span>
                            </button>
                            <div class="faq-content">
                                <div class="faq-body">
                                    <p>{t(`faq.a${i}` as any)}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Schema Injection (Server-Side) -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

<style>
    .faq-section {
        background-color: var(--blue-900);
        padding: 150px 0;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    
    .faq-grid {
        display: grid;
        grid-template-columns: 450px 1fr;
        gap: 8rem;
        align-items: start;
    }

    .faq-image-side {
        position: sticky;
        top: 140px;
    }

    .faq-image-container {
        position: relative;
        border-radius: 4px;
    }

    .faq-image-container img {
        width: 100%;
        height: auto;
        aspect-ratio: 4/5;
        object-fit: cover;
        border-radius: 24px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
        position: relative;
        z-index: 2;
        transform: rotate(-1.5deg);
        transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .image-accent-box {
        position: absolute;
        bottom: -20px;
        left: -20px;
        width: 100%;
        height: 100%;
        border: 2px solid var(--accent);
        border-radius: 24px;
        z-index: 1;
        opacity: 0.2;
        transform: rotate(1.5deg);
    }

    .faq-trigger {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2.5rem 0;
        background: none;
        border: none;
        cursor: pointer;
        text-align: left;
        color: var(--white);
        font-size: clamp(1.1rem, 1.5vw, 1.3rem);
        font-weight: var(--fw-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.3s ease;
    }
    
    .faq-icon {
        position: relative;
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        margin-left: 1.5rem;
    }
    
    .faq-icon::before, .faq-icon::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: var(--accent);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .faq-icon::before { width: 100%; height: 2px; }
    .faq-icon::after { width: 2px; height: 100%; }

    .faq-trigger[aria-expanded="true"] .faq-icon::after {
        transform: translate(-50%, -50%) rotate(90deg);
        opacity: 0;
    }
    
    .faq-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .faq-body p {
        color: rgba(255,255,255,0.6);
        font-size: 1.1rem;
        line-height: 1.7;
        padding-bottom: 3rem;
    }

    @media (max-width: 900px) {
        .faq-grid {
            grid-template-columns: 1fr;
            gap: 4rem;
        }
        .faq-image-side {
            position: static;
        }
    }
</style>

<script is:inline>
    function initAccordion() {
        const triggers = document.querySelectorAll('.faq-trigger');
        triggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                const expanded = trigger.getAttribute('aria-expanded') === 'true';
                const content = trigger.nextElementSibling;
                
                requestAnimationFrame(() => {
                    triggers.forEach(t => {
                        if (t !== trigger) {
                            t.setAttribute('aria-expanded', 'false');
                            t.nextElementSibling.style.maxHeight = null;
                        }
                    });

                    const nextState = !expanded;
                    trigger.setAttribute('aria-expanded', nextState);
                    content.style.maxHeight = nextState ? content.scrollHeight + "px" : null;
                });
            });
        });
    }
    document.addEventListener('astro:page-load', initAccordion);
</script>
