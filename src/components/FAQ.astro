---
const base = import.meta.env.BASE_URL;
---
<section class="section faq-section" id="faq">
    <div class="container">
        <div class="faq-grid">
            <!-- Columna Izquierda: Imagen -->
            <div class="faq-image-side reveal">
                <div class="faq-image-container">
                    <img src={`${base}/img/work-3.webp`} alt="Gestoo MICE & Logistics" loading="lazy" />
                    <div class="image-accent-box"></div>
                </div>
            </div>

            <!-- Columna Derecha: Contenido -->
            <div class="faq-content-side">
                <div class="section-header reveal">
                    <span class="tag" data-i18n="faq-tag">Consultas</span>
                    <h2 class="section-title" data-i18n="faq-title">Preguntas <em>frecuentes.</em></h2>
                </div>

                <div class="faq-accordion reveal">
                    {[1, 2, 3, 4].map((i) => (
                        <div class="faq-item">
                            <button class="faq-trigger" aria-expanded="false" id={`faq-btn-${i}`}>
                                <span data-i18n={`faq-q${i}`}>Pregunta...</span>
                                <span class="faq-icon"></span>
                            </button>
                            <div class="faq-content">
                                <div class="faq-body">
                                    <p data-i18n={`faq-a${i}`}>Respuesta...</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .faq-section {
        background-color: var(--blue-900);
        padding: 150px 0;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    
    .faq-grid {
        display: grid;
        grid-template-columns: 450px 1fr;
        gap: 8rem;
        align-items: start;
    }

    /* Lado Imagen */
    .faq-image-side {
        position: sticky;
        top: 140px;
    }

    .faq-image-container {
        position: relative;
        border-radius: 4px;
        overflow: visible; /* Cambiado para que el box de acento se vea */
    }

    .faq-image-container img {
        width: 100%;
        height: auto;
        aspect-ratio: 4/5;
        object-fit: cover;
        border-radius: 24px; /* Estilo Gestoo: bordes muy redondeados */
        box-shadow: 0 30px 60px rgba(0,0,0,0.4); /* Sombra profunda para dar relieve */
        position: relative;
        z-index: 2;
        transform: rotate(-1.5deg); /* Ligera inclinación para dinamismo */
        transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .faq-image-container:hover img {
        transform: rotate(0deg) scale(1.02);
    }

    .image-accent-box {
        position: absolute;
        bottom: -20px;
        left: -20px;
        width: 100%;
        height: 100%;
        border: 2px solid var(--accent);
        border-radius: 24px; /* Match corners */
        z-index: 1;
        opacity: 0.2;
        transform: rotate(1.5deg); /* Inclinación opuesta para el box */
    }

    /* Lado Contenido */
    .faq-content-side {
        padding-top: 2rem;
    }

    .faq-content-side .section-header {
        margin-bottom: 4rem;
    }

    .faq-accordion {
        border-top: 1px solid rgba(255,255,255,0.1);
    }
    
    .faq-item {
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .faq-trigger {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2.5rem 0;
        background: none;
        border: none;
        cursor: pointer;
        text-align: left;
        color: var(--white);
        font-size: clamp(1.1rem, 1.5vw, 1.3rem);
        font-weight: var(--fw-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.3s ease;
    }
    
    .faq-trigger:hover {
        color: var(--accent);
    }
    
    .faq-icon {
        position: relative;
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        margin-left: 1.5rem;
    }
    
    .faq-icon::before, .faq-icon::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: var(--accent);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .faq-icon::before { width: 100%; height: 2px; }
    .faq-icon::after { width: 2px; height: 100%; }

    .faq-trigger[aria-expanded="true"] .faq-icon::after {
        transform: translate(-50%, -50%) rotate(90deg);
        opacity: 0;
    }
    
    .faq-trigger[aria-expanded="true"] {
        color: var(--accent);
    }

    .faq-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .faq-body {
        padding: 0 0 3rem;
    }
    
    .faq-body p {
        color: rgba(255,255,255,0.6);
        font-size: 1.1rem;
        line-height: 1.7;
    }

    /* Breakpoint más bajo para forzar el modo escritorio en más pantallas */
    @media (max-width: 900px) {
        .faq-grid {
            grid-template-columns: 1fr;
            gap: 4rem;
        }
        .faq-image-side {
            position: static;
            max-width: 100%;
            margin-bottom: 2rem;
        }
        .image-accent-box {
            display: none;
        }
    }
</style>

<script is:inline>
    function initAccordion() {
        const triggers = document.querySelectorAll('.faq-trigger');
        triggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                const expanded = trigger.getAttribute('aria-expanded') === 'true';
                const content = trigger.nextElementSibling;
                
                // Usamos requestAnimationFrame para evitar layout thrashing
                requestAnimationFrame(() => {
                    // Cerrar otros
                    triggers.forEach(t => {
                        if (t !== trigger) {
                            t.setAttribute('aria-expanded', 'false');
                            t.nextElementSibling.style.maxHeight = null;
                        }
                    });

                    // Alternar actual
                    const nextState = !expanded;
                    trigger.setAttribute('aria-expanded', nextState);
                    
                    if (nextState) {
                        // Leemos la medida una sola vez
                        const height = content.scrollHeight;
                        content.style.maxHeight = height + "px";
                    } else {
                        content.style.maxHeight = null;
                    }
                });
            });
        });
    }
    document.addEventListener('astro:page-load', initAccordion);
</script>

<!-- FAQ Schema for AI Search Readiness -->
<script is:inline>
    (function() {
        // Obtenemos las traducciones (asumiendo que translations.js ya cargó)
        // Usamos un pequeño delay para asegurar que el diccionario esté disponible
        setTimeout(() => {
            if (typeof translations === 'undefined') return;
            
            // Detectamos el idioma actual (siguiendo la lógica de i18n.js)
            const currentLang = localStorage.getItem('preferredLanguage') || 'es';
            const t = translations[currentLang];
            
            const schema = {
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "mainEntity": [1, 2, 3, 4].map(i => ({
                    "@type": "Question",
                    "name": t[`faq-q${i}`],
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": t[`faq-a${i}`]
                    }
                }))
            };

            const script = document.createElement('script');
            script.type = 'application/ld+json';
            script.id = 'faq-schema';
            script.text = JSON.stringify(schema);
            document.head.appendChild(script);
        }, 500);
    })();
</script>
