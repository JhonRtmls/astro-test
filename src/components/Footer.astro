---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={`${base}`} class="footer-logo">
          <img src={`${base}/img/logo.png`} alt="Gestoo" />
        </a>
        <p data-i18n="footer-desc">
          Potenciando negocios a través de experiencias creativas.<br />Punta
          Arenas, Chile.
        </p>
      </div>

      <div class="footer-nav-group">
        <div class="footer-nav">
          <h3 data-i18n="footer-agency">Agencia</h3>
          <nav class="footer-links">
            <a href={`${base}/about`} data-i18n="nav-about">Quiénes somos</a>
            <a href={`${base}/services`} data-i18n="nav-services">Servicios</a>
            <a href={`${base}/works`} data-i18n="nav-works">Proyectos</a>
            <a href={`${base}/contact`} data-i18n="nav-contact">Contacto</a>
          </nav>
        </div>
        <div class="footer-specialties">
          <h3 data-i18n="footer-specialties">Especialidades</h3>
          <nav class="footer-links">
            <a href="#" data-i18n="footer-spec-1">Marketing B2B</a>
            <a href="#" data-i18n="footer-spec-2">Producción MICE</a>
            <a href="#" data-i18n="footer-spec-3">Alquiler de Equipos</a>
          </nav>
        </div>
        <div class="footer-contact">
          <h3 data-i18n="footer-contact">Contacto</h3>
          <a href="#" class="email-link" data-name="contacto" data-domain="gestoo.cl">Cargando email...</a>
          <p>Punta Arenas, Chile</p>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>
        &copy; {currentYear} Gestoo Creative Agency. Todos los derechos reservados.
      </p>
      <div class="footer-socials">
        <a href="https://www.instagram.com/agenciagestoo/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link">
          <img src={`${base}/img/redes_sociales_icons/instagram.svg`} alt="Instagram" loading="lazy" width="24" height="24" />
        </a>
        <a href="https://www.linkedin.com/in/agenciagestoo/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-link">
          <img src={`${base}/img/redes_sociales_icons/linkedin.svg`} alt="LinkedIn" loading="lazy" width="24" height="24" />
        </a>
      </div>
    </div>
  </div>
</footer>
