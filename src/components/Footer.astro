---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={`${base}/`} class="footer-logo">
          <img src={`${base}/img/logo.png`} alt="Gestoo" />
        </a>
        <p data-i18n="footer-desc">
          Potenciando negocios a través de experiencias creativas.<br />Punta
          Arenas, Chile.
        </p>
      </div>

      <div class="footer-nav-group">
        <div class="footer-nav">
          <h4 data-i18n="footer-agency">Agencia</h4>
          <nav class="footer-links">
            <a href={`${base}/about`} data-i18n="nav-about">Quiénes somos</a>
            <a href={`${base}/services`} data-i18n="nav-services">Servicios</a>
            <a href={`${base}/works`} data-i18n="nav-works">Proyectos</a>
            <a href={`${base}/contact`} data-i18n="nav-contact">Contacto</a>
          </nav>
        </div>
        <div class="footer-specialties">
          <h4 data-i18n="footer-specialties">Especialidades</h4>
          <nav class="footer-links">
            <a href="#" data-i18n="footer-spec-1">Marketing B2B</a>
            <a href="#" data-i18n="footer-spec-2">Producción MICE</a>
            <a href="#" data-i18n="footer-spec-3">Alquiler de Equipos</a>
          </nav>
        </div>
        <div class="footer-contact">
          <h4 data-i18n="footer-contact">Contacto</h4>
          <a href="mailto:contacto@gestoo.cl">contacto@gestoo.cl</a>
          <p>Punta Arenas, Chile</p>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>
        &copy; {currentYear} Gestoo Creative Agency. Todos los derechos reservados.
      </p>
      <div class="footer-socials">
        <a href="#" aria-label="YouTube" class="social-link">
          <img src={`${base}/img/redes_sociales_icons/youtube.svg`} alt="" />
        </a>
        <a href="#" aria-label="Instagram" class="social-link">
          <img src={`${base}/img/redes_sociales_icons/instagram.svg`} alt="" />
        </a>
        <a href="#" aria-label="Facebook" class="social-link">
          <img src={`${base}/img/redes_sociales_icons/facebook.svg`} alt="" />
        </a>
        <a href="#" aria-label="LinkedIn" class="social-link">
          <img src={`${base}/img/redes_sociales_icons/linkedin.svg`} alt="" />
        </a>
      </div>
    </div>
  </div>
</footer>
