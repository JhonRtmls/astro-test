---
import { Image } from "astro:assets";
import heroImage from "../assets/img/hero.jpg";
---

<div class="hero-visual-wrapper" id="heroVisual">
  <Image
    src={heroImage}
    alt="Gestoo Hero — Leading Creative Agency in Patagonia"
    class="hero-visual-media"
    loading="eager"
    fetchpriority="high"
    widths={[400, 800, 1200, 1920]}
    sizes="100vw"
    format="webp"
  />
  <div class="hero-visual-overlay"></div>
</div>

<style>
  .hero-visual-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 5;
    overflow: hidden;
    pointer-events: none;
    transition: border-radius 0.3s ease;
  }

  .hero-visual-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-visual-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
    z-index: 2;
  }
</style>
