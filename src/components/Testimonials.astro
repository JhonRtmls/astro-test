---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const testimonials = [
  { id: '01' },
  { id: '02' },
  { id: '03' }
];

// Schema.org ItemList (Server-Side for GEO)
const reviewSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": testimonials.map((item, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "item": {
            "@type": "Review",
            "author": {
                "@type": "Person",
                "name": t(`testimonials.${item.id}.name` as any)
            },
            "reviewBody": t(`testimonials.${item.id}.text` as any),
            "reviewRating": {
                "@type": "Rating",
                "ratingValue": "5",
                "bestRating": "5"
            },
            "publisher": {
                "@type": "Organization",
                "name": "Gestoo"
            }
        }
    }))
};
---

<section class="testimonials-section section" id="testimonials">
  <div class="container">
    <div class="section-header reveal text-center">
      <span class="tag">{t('testimonials.tag')}</span>
      <h2 class="section-title">{t('testimonials.title')} <em>{t('testimonials.title_accent')}</em></h2>
    </div>

    <div class="testimonials-container reveal">
      <div class="testimonials-track">
        {testimonials.map((item) => (
          <div class="testimonial-card">
            <figure class="testimonial-figure">
              <div class="testimonial-quote">
                <svg width="40" height="30" viewBox="0 0 40 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 17.1429V0H14.2857V17.1429H5.71429C5.71429 21.8857 9.54286 25.7143 14.2857 25.7143V30C7.17143 30 0 22.8286 0 17.1429ZM25.7143 17.1429V0H40V17.1429H31.4286C31.4286 21.8857 35.2571 25.7143 40 25.7143V30C32.8857 30 25.7143 22.8286 25.7143 17.1429Z" fill="var(--accent)" fill-opacity="0.2"/>
                </svg>
              </div>
              <blockquote class="testimonial-text">
                <p>"{t(`testimonials.${item.id}.text` as any)}"</p>
              </blockquote>
              <figcaption class="testimonial-author">
                <div class="author-info">
                  <cite class="author-name">{t(`testimonials.${item.id}.name` as any)}</cite>
                  <span class="author-role">{t(`testimonials.${item.id}.role` as any)}</span>
                </div>
              </figcaption>
            </figure>
          </div>
        ))}
      </div>
      
      <div class="testimonials-nav">
        <button class="nav-btn prev" aria-label={t('nav.prev')}>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <button class="nav-btn next" aria-label={t('nav.next')}>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- Schema Injection -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(reviewSchema)} />

<style>
  .testimonials-section {
    background-color: var(--blue-900);
    overflow: hidden;
    padding: 120px 0;
  }

  .text-center {
    text-align: center;
    margin-bottom: 4rem;
  }

  .testimonials-container {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
  }

  .testimonials-track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .testimonial-card {
    min-width: 100%;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .testimonial-quote {
    margin-bottom: 2rem;
  }

  .testimonial-text {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.5;
    color: var(--white);
    font-style: italic;
    margin-bottom: 3rem;
    max-width: 800px;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .author-info {
    text-align: center;
  }

  .author-name {
    display: block;
    font-size: 1.1rem;
    font-weight: var(--fw-bold);
    color: var(--white);
    margin-bottom: 0.25rem;
  }

  .author-role {
    font-size: 0.9rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .testimonials-nav {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 4rem;
  }

  .nav-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--white);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .nav-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: scale(1.1);
  }
</style>

<script is:inline>
  function initTestimonials() {
    const track = document.querySelector('.testimonials-track');
    const cards = document.querySelectorAll('.testimonial-card');
    const nextBtn = document.querySelector('.nav-btn.next');
    const prevBtn = document.querySelector('.nav-btn.prev');
    
    // GUARD: Check if all elements exist and cast to HTMLElement for .style access
    if (!track || !nextBtn || !prevBtn || cards.length === 0) return;

    let currentIndex = 0;
    const trackEl = track;

    function updateCarousel() {
      requestAnimationFrame(() => {
        const offset = currentIndex * -100;
        trackEl.style.transform = `translateX(${offset}%)`;
      });
    }

    nextBtn.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % cards.length;
      updateCarousel();
    });

    prevBtn.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + cards.length) % cards.length;
      updateCarousel();
    });
  }

  initTestimonials();
  document.addEventListener('astro:page-load', initTestimonials);
</script>
