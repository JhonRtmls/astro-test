---
const base = import.meta.env.BASE_URL;

const testimonials = [
  {
    nombre: "Ariel Bravo",
    cargo: "Branch Manager",
    empresa: "Ultramar",
    testimonio: "La experiencia de Gestoo para nuestra fiesta de aniversario Nº 65 fue cautivadora e innovadora. El equipo se preocupó hasta del más mínimo detalle, mostrando todo su profesionalismo en eventos de alto nivel.",
    imagen: "/img/testimonials/ariel.jpg"
  },
  {
    nombre: "Ximena Castro",
    cargo: "Gerenta",
    empresa: "Parque del Estrecho",
    testimonio: "Siempre nos han brindado experiencias memorables; su profesionalismo, creatividad y atención al detalle han sido claves para el éxito. Recomiendo a Gestoo como un socio confiable y talentoso.",
    imagen: "/img/testimonials/ximena.jpg"
  },
  {
    nombre: "Claudio Magallanes",
    cargo: "Outdoorsttv",
    empresa: "",
    testimonio: "Fue un agrado trabajar con una empresa que se notó profesional en todo momento. En Chile no es fácil encontrar partners que cubran la gestión y logística con este nivel de excelencia.",
    imagen: "/img/testimonials/claudio.jpg"
  },
  {
    nombre: "Miriam Urra",
    cargo: "Mamá Outdoor",
    empresa: "",
    testimonio: "Fue una experiencia extraordinaria. En todo momento me sentí segura y acompañada. Se notó el trabajo previo de organización porque realmente fue todo un éxito. Preocupados de cada detalle.",
    imagen: "/img/testimonials/miriam.jpg"
  },
  {
    nombre: "Facundo Armas",
    cargo: "Cantante",
    empresa: "Argentina",
    testimonio: "He trabajado con muchos productores, pero la experiencia con Gestoo fue de las mejores. Profesionalidad, gran atención y un hermoso grupo humano. Saludos desde Argentina.",
    imagen: "/img/testimonials/facundo.jpg"
  },
  {
    nombre: "César Ulloa Serón",
    cargo: "Diseñador Gráfico",
    empresa: "Sucvisual",
    testimonio: "Llevamos años siendo soporte de producción y ha sido una experiencia laboral enriquecedora. Esperamos seguir realizando proyectos junto a ellos por mucho tiempo.",
    imagen: "/img/testimonials/cesar.jpg"
  }
];
---

<section class="testimonials-section section" id="testimonials">
  <div class="container">
    <div class="section-header reveal text-center">
      <span class="tag" data-i18n="testimonials-tag">Experiencias</span>
      <h2 class="section-title" data-i18n="testimonials-title">Lo que dicen de <em>nosotros.</em></h2>
    </div>

    <div class="testimonials-container reveal">
      <div class="testimonials-track">
        {testimonials.map((t) => (
          <div class="testimonial-card">
            <div class="testimonial-quote">
              <svg width="40" height="30" viewBox="0 0 40 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 17.1429V0H14.2857V17.1429H5.71429C5.71429 21.8857 9.54286 25.7143 14.2857 25.7143V30C7.17143 30 0 22.8286 0 17.1429ZM25.7143 17.1429V0H40V17.1429H31.4286C31.4286 21.8857 35.2571 25.7143 40 25.7143V30C32.8857 30 25.7143 22.8286 25.7143 17.1429Z" fill="var(--accent)" fill-opacity="0.2"/>
              </svg>
            </div>
            <p class="testimonial-text">{t.testimonio}</p>
            <div class="testimonial-author">
              <div class="author-info">
                <span class="author-name">{t.nombre}</span>
                <span class="author-role">{t.cargo} {t.empresa ? `| ${t.empresa}` : ''}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="testimonials-nav">
        <button class="nav-btn prev" aria-label="Anterior">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <button class="nav-btn next" aria-label="Siguiente">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    background-color: var(--blue-900);
    overflow: hidden;
    padding: 120px 0;
  }

  .text-center {
    text-align: center;
    margin-bottom: 4rem;
  }

  .testimonials-container {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
  }

  .testimonials-track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .testimonial-card {
    min-width: 100%;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .testimonial-quote {
    margin-bottom: 2rem;
  }

  .testimonial-text {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.5;
    color: var(--white);
    font-style: italic;
    margin-bottom: 3rem;
    max-width: 800px;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .author-info {
    text-align: center;
  }

  .author-name {
    display: block;
    font-size: 1.1rem;
    font-weight: var(--fw-bold);
    color: var(--white);
    margin-bottom: 0.25rem;
  }

  .author-role {
    font-size: 0.9rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .testimonials-nav {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 4rem;
  }

  .nav-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--white);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .nav-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: scale(1.1);
  }
</style>

<script>
  function initTestimonials() {
    const track = document.querySelector('.testimonials-track');
    const cards = document.querySelectorAll('.testimonial-card');
    const nextBtn = document.querySelector('.nav-btn.next');
    const prevBtn = document.querySelector('.nav-btn.prev');
    
    if (!track || cards.length === 0) return;

    let currentIndex = 0;

    function updateCarousel() {
      const offset = currentIndex * -100;
      track.style.transform = `translateX(${offset}%)`;
    }

    nextBtn.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % cards.length;
      updateCarousel();
    });

    prevBtn.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + cards.length) % cards.length;
      updateCarousel();
    });
  }

  // Ejecutar al cargar y después de transiciones
  initTestimonials();
  document.addEventListener('astro:after-swap', initTestimonials);
</script>
