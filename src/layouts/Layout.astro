---
interface Props {
	title: string;
    description?: string;
    keywords?: string;
}

import '../styles/reset.css';
import '../styles/variables.css';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/lenis.css';
import { ClientRouter } from 'astro:transitions';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import fontNormal from '../assets/fonts/Montserrat-VariableFont_wght.ttf';
import fontItalic from '../assets/fonts/Montserrat-Italic-VariableFont_wght.ttf';

const { title, description = "Agencia creativa líder en Punta Arenas y la Patagonia Chilena. Especialistas en branding, turismo MICE, producción técnica de eventos y logística.", keywords } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const site = Astro.site || new URL('https://jhonrtmls.github.io/astro-test');
const canonicalURL = new URL(Astro.url.pathname, site);

// Breadcrumb Logic for AI
const pathSegments = Astro.url.pathname.replace('/astro-test', '').replace(/^\/?(es|en)/, '').split('/').filter(Boolean);
const breadcrumbs = [
    { name: lang === 'es' ? 'Inicio' : 'Home', item: `${site.href}/${lang}/` },
    ...pathSegments.map((segment, index) => {
        const path = pathSegments.slice(0, index + 1).join('/');
        return {
            name: segment.charAt(0).toUpperCase() + segment.slice(1),
            item: `${site.href}/${lang}/${path}`
        };
    })
];
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/astro-test/img/favicon.png" />
		<meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        {keywords && <meta name="keywords" content={keywords} />}

        <!-- Performance: Preconnect to Analytics/GTM -->
        <link rel="preconnect" href="https://www.googletagmanager.com">
        <link rel="preconnect" href="https://www.google-analytics.com">

        <!-- Google Tag Manager -->
		<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-T3TDG6QC');</script>
		<!-- End Google Tag Manager -->
        
        <meta name="author" content="Gestoo" />
        <!-- Critical Font Preloading -->
        <link rel="preload" href={fontNormal} as="font" type="font/ttf" crossorigin="anonymous" />
        <link rel="preload" href={fontItalic} as="font" type="font/ttf" crossorigin="anonymous" />

        <!-- Language targeting (SEO) -->
        <link rel="alternate" hreflang="es" href={new URL(Astro.url.pathname.replace(/^\/(en|es)/, '/es'), site)} />
        <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^\/(en|es)/, '/en'), site)} />
        <link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname.replace(/^\/(en|es)/, '/es'), site)} />
        
        <link rel="canonical" href={canonicalURL} />

        <!-- Schema.org -->
        <script type="application/ld+json" is:inline set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "Organization",
                    "@id": `${site.href}#organization`,
                    "name": "Gestoo",
                    "url": site.href,
                    "logo": {
                        "@type": "ImageObject",
                        "url": new URL('/astro-test/img/logo-dark.png', site).href
                    }
                },
                {
                    "@type": "ProfessionalService",
                    "name": "Gestoo",
                    "url": canonicalURL,
                    "telephone": "+56981887723",
                    "email": "contacto@gestoo.cl",
                    "priceRange": "$$$",
                    "areaServed": ["Punta Arenas", "Magallanes", "Chile", "Antarctica", "Patagonia"],
                    "hasOfferCatalog": {
                        "@type": "OfferCatalog",
                        "name": "Servicios de Producción",
                        "itemListElement": [
                            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Branding & Identidad" } },
                            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Turismo MICE" } },
                            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Producción Técnica de Eventos" } },
                            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Logística en Patagonia" } }
                        ]
                    },
                    "address": {
                        "@type": "PostalAddress",
                        "streetAddress": "Av. Independencia 313",
                        "addressLocality": "Punta Arenas",
                        "addressRegion": "Magallanes",
                        "postalCode": "6200000",
                        "addressCountry": "CL"
                    }
                }
            ]
        })} />

        <!-- GSAP & Lenis optimized -->
        <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
        <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
        <script is:inline defer src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
        
        <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" /></noscript>
        <ClientRouter />

        <script is:inline>
            document.addEventListener('astro:page-load', () => {
                window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
                if (window.lenis) window.lenis.scrollTo(0, { immediate: true });
            });
        </script>
	</head>
	<body>
        <a href="#main-content" class="skip-link">{t('nav.about') === 'Nosotros' ? 'Saltar al contenido' : 'Skip to content'}</a>
		<slot />
        <WhatsAppButton phone="+56981887723" />
        <script is:inline src="/astro-test/js/main.js"></script>
	</body>
</html>


<style is:global>
	/* Global styles if needed */
</style>
