---
interface Props {
	title: string;
    description?: string;
}

const { title, description = "Agencia creativa líder en Punta Arenas y la Patagonia Chilena. Especialistas en branding, turismo MICE, producción técnica de eventos y logística." } = Astro.props;

import '../styles/reset.css';
import '../styles/variables.css';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/lenis.css';
import { ClientRouter } from 'astro:transitions';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Breadcrumb Logic for AI
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbs = [
    { name: 'Inicio', item: Astro.site.href },
    ...pathSegments.map((segment, index) => {
        const url = new URL(pathSegments.slice(0, index + 1).join('/'), Astro.site);
        return {
            name: segment.charAt(0).toUpperCase() + segment.slice(1),
            item: url.href
        };
    })
];
---

<!doctype html>
<html lang="es">
	<head>
		<!-- Google Tag Manager -->
		<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-T3TDG6QC');</script>
		<!-- End Google Tag Manager -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/img/favicon.png`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
        <meta name="description" content={description} />
        
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(`${import.meta.env.BASE_URL}/img/hero.jpg`, Astro.site)} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(`${import.meta.env.BASE_URL}/img/hero.jpg`, Astro.site)} />

        <link rel="canonical" href={canonicalURL} />

        <script type="application/ld+json" is:inline>
            {
                "@context": "https://schema.org",
                "@type": "ProfessionalService",
                "name": "Gestoo",
                "url": "https://gestoo.cl/astro-test/",
                "logo": "https://gestoo.cl/astro-test/img/logo-dark.png",
                "image": "https://gestoo.cl/astro-test/img/hero.jpg",
                "description": "Agencia creativa líder en Punta Arenas y la Patagonia Chilena. Especialistas en branding, turismo MICE, producción técnica de eventos y logística B2B.",
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "Av. Independencia 313",
                    "addressLocality": "Punta Arenas",
                    "addressRegion": "Magallanes",
                    "postalCode": "6200000",
                    "addressCountry": "CL"
                },
                "geo": {
                    "@type": "GeoCoordinates",
                    "latitude": -53.1626,
                    "longitude": -70.9078
                },
                "telephone": "+56981887723",
                "email": "contacto@gestoo.cl",
                "priceRange": "$$$",
                "areaServed": [
                    {
                        "@type": "Country",
                        "name": "Chile"
                    },
                    {
                        "@type": "AdministrativeArea",
                        "name": "Patagonia"
                    }
                ],
                "knowsAbout": [
                    "Branding Corporativo",
                    "Turismo MICE",
                    "Producción de Eventos",
                    "Logística en Climas Extremos",
                    "Marketing B2B"
                ],
                "sameAs": [
                    "https://www.linkedin.com/company/gestoo",
                    "https://www.instagram.com/gestoo.cl"
                ]
            }
        </script>

        <!-- GSAP & Lenis optimized (added defer to prevent render blocking) -->
        <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
        <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
        <script is:inline defer src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
        
        <!-- FontAwesome optimized -->
        <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" /></noscript>
        <ClientRouter />

        <script type="application/ld+json" is:inline set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": breadcrumbs.map((bc, i) => ({
                "@type": "ListItem",
                "position": i + 1,
                "name": bc.name,
                "item": bc.item
            }))
        })} />

        <!-- Script de Reseteo Crítico y Utilidades -->
        <script is:inline>
            if ('scrollRestoration' in history) {
                history.scrollRestoration = 'manual';
            }

            function decodeEmails() {
                document.querySelectorAll('.email-link').forEach(link => {
                    const user = link.getAttribute('data-name');
                    const domain = link.getAttribute('data-domain');
                    if (user && domain) {
                        const email = `${user}@${domain}`;
                        link.href = `mailto:${email}`;
                        link.textContent = email;
                    }
                });
            }

            // Ejecutar al cargar y después de cada transición de Astro
            decodeEmails();
            document.addEventListener('astro:after-swap', () => {
                decodeEmails();
                window.scrollTo(0, 0);
                if (window.lenis) {
                    window.lenis.scrollTo(0, { immediate: true });
                }
            });
        </script>
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T3TDG6QC"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<div class="cursor"></div>
        <div class="cursor-follower"></div>
		<slot />
        
        <!-- Scripts -->
        <script is:inline src={`${import.meta.env.BASE_URL}/js/translations.js`}></script>
        <script is:inline src={`${import.meta.env.BASE_URL}/js/i18n.js`}></script>
        <script is:inline src={`${import.meta.env.BASE_URL}/js/main.js`}></script>
	</body>
</html>

<style is:global>
	/* Global styles if needed */
</style>
