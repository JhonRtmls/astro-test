---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/pages/inner.css';
import '../styles/pages/about.css';
const base = import.meta.env.BASE_URL;
---

<Layout title="Gestoo | Nosotros">
    <Navbar />
    <img src={`${base}/img/antartica.svg`} alt="" class="bg-illustration">
    <main>
        <section class="page-hero">
            <div class="container page-hero-content">
                <div class="reveal">
                    <span class="tag" data-i18n="about-hero-tag">ADN Patagónico</span>
                    <h1 class="page-title" data-i18n="about-hero-title">Transformamos visión en <br><span class="gradient-text">impacto real.</span></h1>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="container">
                <div class="about-intro">
                    <div class="about-intro-text reveal">
                        <h2 data-i18n="about-intro-title">Una agencia creativa que diseña el futuro de los eventos en la Patagonia.</h2>
                        <p data-i18n="about-intro-p1">Nacimos con la convicción de que un evento no es solo una reunión de personas: es una oportunidad para crear algo memorable. Somos un equipo apasionado por los detalles, por la narrativa y por el impacto emocional.</p>
                        <p data-i18n="about-intro-p2">Desde Punta Arenas llevamos nuestras experiencias a todo Chile, combinando la majestuosidad de la Patagonia con la creatividad de una agencia de clase mundial.</p>
                        <br>
                        <a href={`${base}contact`} class="btn-primary" data-i18n="about-intro-btn">Trabaja con nosotros</a>
                    </div>
                    <div class="about-img-block reveal">
                        <img src={`${base}/img/team.jpg`} alt="Equipo Gestoo">
                    </div>
                </div>
            </div>
        </section>

        <section class="section" style="background: var(--surface);">
            <div class="container">
                <div class="testimonial-inner reveal" style="max-width:800px; margin:0 auto; text-align:center; position:relative;">
                    <blockquote>
                        <p data-i18n="about-quote">No organizamos eventos. <br>Diseñamos experiencias que transforman momentos en recuerdos que duran toda la vida.</p>
                    </blockquote>
                    <cite><strong data-i18n="about-quote-cite">El Equipo Gestoo</strong></cite>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="container">
                <div class="section-header reveal">
                    <span class="tag" data-i18n="about-pilares-tag">Metodología</span>
                    <h2 class="section-title" data-i18n="about-pilares-title">Nuestros pilares<br><em>estratégicos.</em></h2>
                </div>
                <div class="values-grid">
                    <div class="value-card reveal">
                        <div class="value-icon">01</div>
                        <h3 data-i18n="about-pilar-1-title">Pensamiento Estratégico</h3>
                        <p data-i18n="about-pilar-1-desc">No solo ejecutamos; analizamos tus objetivos de negocio para que cada evento y marca sea una inversión medida.</p>
                    </div>
                    <div class="value-card reveal">
                        <div class="value-icon">02</div>
                        <h3 data-i18n="about-pilar-2-title">Ingeniería de Experiencias</h3>
                        <p data-i18n="about-pilar-2-desc">Combinamos logística compleja con tecnología audiovisual avanzada para crear momentos sin fricción.</p>
                    </div>
                    <div class="value-card reveal">
                        <div class="value-icon">03</div>
                        <h3 data-i18n="about-pilar-3-title">Ejecución Impecable</h3>
                        <p data-i18n="about-pilar-3-desc">Desde el primer boceto hasta el desmontaje, nuestra atención al detalle en la Patagonia es quirúrgica.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section team-section">
            <div class="container">
                <div class="section-header reveal">
                    <span class="tag" data-i18n="about-team-tag">Capital Humano</span>
                    <h2 class="section-title" data-i18n="about-team-title">El equipo detrás de<br><em>la magia.</em></h2>
                </div>
                <div class="team-grid">
                    <div class="team-card reveal">
                        <div class="team-img-wrapper">
                            <div class="team-img-placeholder"></div>
                            <img src={`${base}/img/team/member1.jpg`} alt="Jaime Almonacid" class="team-img" onerror="this.style.display='none'">
                        </div>
                        <div class="team-info">
                            <span class="team-role">Cargo / Especialidad</span>
                            <h3>Jaime Almonacid</h3>
                            <p>Estratega creativo con enfoque en soluciones B2B y experiencias de marca.</p>
                        </div>
                    </div>
                    <div class="team-card reveal">
                        <div class="team-img-wrapper">
                            <div class="team-img-placeholder"></div>
                            <img src={`${base}/img/team/member2.jpg`} alt="Paola Almonacid Vargas" class="team-img" onerror="this.style.display='none'">
                        </div>
                        <div class="team-info">
                            <span class="team-role">Producción Técnica</span>
                            <h3>Paola Almonacid Vargas</h3>
                            <p>Experto en ingeniería audiovisual y logística de eventos de alto impacto.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="section solution-section">
            <div class="container content-contained">
                <div class="solution-card reveal">
                    <span class="tag" data-i18n="about-cta-tag">Problem Solvers</span>
                    <h2 class="cta-title" data-i18n="about-cta-title">¿Tienes un desafío? <br> Somos la <span class="solution-highlight">solución.</span></h2>
                    <p data-i18n="about-cta-desc">Optimizamos procesos, elevamos tu marca y garantizamos que cada evento sea una inversión, no un gasto. Tu éxito es nuestra métrica.</p>
                    <a href={`${base}contact`} class="btn-orange-glow" data-i18n="about-cta-btn">Cotiza tu solución ahora →</a>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>
