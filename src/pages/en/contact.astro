---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/pages/inner.css";
import "../../styles/pages/contact.css";
import pinguino from "../../assets/img/pinguino.svg";
---

<Layout 
  title="Gestoo | Contact"
  keywords="contact gestoo, quote events patagonia, branding services chile, punta arenas office, technical production budget"
>
  <Navbar />
  <img src={pinguino.src} alt="" class="bg-asset asset-pinguino" />
  <main id="main-content">
    <section class="section contact-section">
      <div class="container content-contained">
        <div class="contact-grid">
          <div class="contact-info-column reveal">
            <span class="tag">Contact</span>
            <h1 class="page-title" style="margin-bottom: 2rem">
              Experts in <br /><span class="gradient-text">MICE & B2B solutions.</span>
            </h1>
            <p class="contact-description">
              From Patagonia to all of Chile, we transform complexity into memorable experiences. Tell us what you have in mind.
            </p>

            <div class="contact-methods">
              <div class="method-item">
                <div class="method-icon"><img src="/astro-test/img/contacto_icons/location.svg" alt="Location" /></div>
                <div class="method-text">
                  <label>Location</label>
                  <p>Av. Independencia 313, <br />Punta Arenas, Magallanes, Chile</p>
                </div>
              </div>
              <div class="method-item">
                <div class="method-icon"><img src="/astro-test/img/contacto_icons/mail.svg" alt="Email" /></div>
                <div class="method-text">
                  <label>Corporate Email</label>
                  <a href="#" class="email-link" data-name="contacto" data-domain="gestoo.cl">Loading email...</a>
                </div>
              </div>
            </div>
          </div>

          <div class="contact-form-column reveal">
            <form class="premium-form" id="contactForm">
              <div class="form-row">
                <div class="form-group">
                  <label>Full Name *</label>
                  <input type="text" name="name" placeholder="e.g. John Doe" required />
                </div>
                <div class="form-group">
                  <label>Company / Institution</label>
                  <input type="text" name="company" placeholder="Your organization" />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>Corporate Email *</label>
                  <input type="email" name="email" placeholder="email@example.com" required />
                </div>
                <div class="form-group">
                  <label>Phone Number</label>
                  <input type="tel" name="phone" placeholder="+56 9 ..." />
                </div>
              </div>

              <div class="form-group">
                <label>Service of Interest</label>
                <select name="service">
                  <option value="">Select an option</option>
                  <option value="branding">Branding & Identity</option>
                  <option value="mice">MICE Tourism</option>
                  <option value="produccion">Technical Production</option>
                  <option value="logistica">Patagonia Logistics</option>
                  <option value="otros">Others / Not sure</option>
                </select>
              </div>

              <div class="form-group">
                <label>Message or Request *</label>
                <textarea name="message" rows="4" placeholder="How can we help you?" required></textarea>
              </div>

              <div class="form-submit">
                <button type="submit" class="btn-orange-glow" id="submitBtn">
                  Send Request →
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
        const emailLink = document.querySelector('.email-link');
        if (emailLink) {
            const user = emailLink.getAttribute('data-name');
            const domain = emailLink.getAttribute('data-domain');
            const fullEmail = `${user}@${domain}`;
            emailLink.href = `mailto:${fullEmail}`;
            emailLink.textContent = fullEmail;
        }

        const contactForm = document.getElementById("contactForm");
        if (contactForm) {
          contactForm.addEventListener("submit", function (e) {
            e.preventDefault();
            const btn = document.getElementById("submitBtn");
            const originalText = btn.textContent;
            btn.textContent = "Sending...";
            btn.disabled = true;
            
            setTimeout(() => {
              alert("Thank you. We have received your request and will contact you shortly.");
              btn.textContent = originalText;
              btn.disabled = false;
              contactForm.reset();
            }, 1500);
          });
        }
    });
  </script>
</Layout>
