---
import Layout from "../../layouts/Layout.astro";
import BrandMarquee from "../../components/BrandMarquee.astro";
import Navbar from "../../components/Navbar.astro";
import HeroVisual from "../../components/HeroVisual.astro";
import Footer from "../../components/Footer.astro";
import FAQ from "../../components/FAQ.astro";
import Testimonials from "../../components/Testimonials.astro";
import SocialHero from "../../components/SocialHero.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import "../../styles/pages/home.css";

// Assets
import imgMarca from "../../assets/img/service-marca.jpg";
import imgMice from "../../assets/img/service-mice.jpg";
import imgProduccion from "../../assets/img/service-produccion.jpg";
import imgRenting from "../../assets/img/service-renting.jpg";
import infinito from "../../assets/img/infinito.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch projects from Content Collections
const allProjects = await getCollection("projects", ({ id }) => id.startsWith(`${lang}/`));
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<Layout 
  title={lang === 'es' ? "Gestoo | Producción Técnica y Creativa en Patagonia" : "Gestoo | Technical and Creative Production in Patagonia"}
  keywords="branding, MICE tourism, event production, punta arenas, patagonia, chile, logistics, corporate events, creative agency patagonia, technical production chile"
>
  <Navbar />
  <main id="main-content">
    <!-- ============ HERO ============ -->
    <section class="hero" id="home">
      <HeroVisual />
      <div class="hero-content container">
      </div>
      <SocialHero />
    </section>

    <!-- ============ MANIFESTO ============ -->
    <section class="manifesto-premium" id="about">
      <div class="manifesto-asset" aria-hidden="true">
        <img src={infinito.src} alt="" />
      </div>

      <div class="manifesto-container">
        <div class="manifesto-grid">
          <div class="manifesto-left">
            <h2 class="manifesto-title">
              {t('home.manifesto.title_01')} <br />
              {t('home.manifesto.title_02')} <br />
              {t('home.manifesto.title_03')} <br />
              {t('home.manifesto.title_04')} <br />
              {t('home.manifesto.title_05')} <br />
              {t('home.manifesto.title_06')}
            </h2>
            <p class="manifesto-subtitle reveal">{t('home.hero.tag')}</p>
            <div class="manifesto-detail-box reveal">
              <p>{t('home.manifesto.desc')}</p>
            </div>
          </div>
          <div class="manifesto-right">
            <div class="hero-target-space" id="heroTarget"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ STRATEGIC MARQUEE ============ -->
    <div class="marquee-wrap strategic-marquee" aria-hidden="true">
      <div class="marquee-track">
        <div class="marquee-block">
          <span>{lang === 'es' ? 'Creatividad' : 'Creativity'}</span><span class="dot"></span>
          <span>{lang === 'es' ? 'Eventos' : 'Events'}</span><span class="dot"></span>
          <span>MICE</span><span class="dot"></span>
          <span>Branding</span><span class="dot"></span>
          <span>Patagonia</span><span class="dot"></span>
          <span>{lang === 'es' ? 'Soluciones' : 'Solutions'}</span><span class="dot"></span>
        </div>
      </div>
    </div>

    <!-- ============ SERVICES HUB ============ -->
    <section class="services-hub" id="services">
      <div class="container hub-container">
        <div class="hub-center">
          <div class="hub-center-circle">
            <h3>{t('services.lead')}</h3>
          </div>
        </div>

        <!-- Anillos concéntricos de fondo -->
        <div class="hub-rings">
          <div class="hub-ring ring-1"></div>
          <div class="hub-ring ring-2"></div>
          <div class="hub-ring ring-3"></div>
        </div>

        <div class="hub-cards">
          {
            [1, 2, 3, 4].map((num) => {
              const imgMap = {
                1: imgMarca,
                2: imgMice,
                3: imgProduccion,
                4: imgRenting
              };
              const imgAsset = imgMap[num as keyof typeof imgMap];
              return (
                <a href={getRelativeLocaleUrl(lang, '/services')} class={`hub-card card-${num}`}>
                  <div class="hub-card-image" style={`background-image: url('${imgAsset.src}')`}></div>
                  <div class="hub-card-content">
                    <span class="hub-card-num">0{num}</span>
                    <h4>{t(`services.0${num}.title` as any)}</h4>
                    <p class="short-desc">{t(`services.0${num}.desc` as any)}</p>
                  </div>
                </a>
              )
            })
          }
        </div>
      </div>
    </section>

    <BrandMarquee />

    <!-- ============ WORKS ============ -->
    <section class="works-section" id="works">
      <div class="container">
        <div class="section-header content-contained">
          <span class="tag">Portfolio</span>
          <h2 class="section-title">
            {lang === 'es' ? 'Casos de' : 'Success'} <em>{lang === 'es' ? 'éxito.' : 'stories.'}</em>
          </h2>
        </div>
      </div>

      <div class="works-grid">
        {featuredProjects.map((project) => (
          <a href={getRelativeLocaleUrl(lang, `/projects/${project.id.split('/').pop()}`)} class="work-link">
            <article class="work-card">
              <div class="work-media">
                {project.data.heroImage && (
                  <Image 
                    src={project.data.heroImage} 
                    alt={project.data.title}
                    width={800}
                    height={600}
                    format="webp"
                  />
                )}
              </div>
              <div class="work-overlay">
                <span class="work-cat">{project.data.category}</span>
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>

    <Testimonials />



    <!-- ============ PROBLEM SOLVER ============ -->
    <section class="solver-section" id="contact">
      <div class="solver-sticky">
        <div class="solver-layer layer-problem">
          <div class="container content-contained">
            <span class="status-badge">{t('cta.challenge')}</span>
            <h2 class="solver-text">
              {lang === 'es' ? '¿NECESITAS PRODUCCIÓN Y LOGÍSTICA PARA TU PRÓXIMO PROYECTO?' : 'NEED PRODUCTION AND LOGISTICS FOR YOUR NEXT PROJECT?'}
            </h2>
          </div>
        </div>
        <div class="solver-layer layer-solution">
          <div class="container content-contained">
            <span class="status-badge white">{lang === 'es' ? 'La Solución' : 'The Solution'}</span>
            <h2 class="solver-text">
              {lang === 'es' 
                ? 'TE AYUDAMOS A QUE CADA PROYECTO SEA UNA INVERSIÓN, NO UN GASTO.' 
                : 'WE HELP YOU MAKE EVERY PROJECT AN INVESTMENT, NOT AN EXPENSE.'}
            </h2>
            <div class="solver-actions">
              <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn-primary">
                {lang === 'es' ? 'COTIZA TU SOLUCIÓN' : 'QUOTE YOUR SOLUTION'}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <FAQ />
  <Footer />
</Layout>

<style>
    .work-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }
</style>
