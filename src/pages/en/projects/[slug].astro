---
import { getCollection, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
	const projects = await getCollection('projects', ({ id }) => id.startsWith('en/'));
	return projects.map((project) => ({
		params: { slug: project.id.split('/').pop() },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${project.data.title} | Gestoo`} description={project.data.description}>
    <Navbar />
    <main class="project-detail-page" id="main-content">
        <header class="project-hero">
            <div class="container content-contained">
                <span class="tag">{project.data.category}</span>
                <h1 class="page-title">{project.data.title}</h1>
                <p class="project-meta">Published on {project.data.pubDate.toLocaleDateString(lang)}</p>
            </div>
            {project.data.heroImage && (
                <div class="hero-image-wrapper container">
                    <Image 
                        src={project.data.heroImage} 
                        alt={project.data.title}
                        width={1400}
                        height={700}
                        format="webp"
                        loading="eager"
                        class="reveal"
                    />
                </div>
            )}
        </header>

        <section class="project-content">
            <div class="container content-contained prose reveal">
                <Content />
            </div>
        </section>
        
        <section class="cta-section">
            <div class="container content-contained">
                <div class="solution-card reveal">
                    <span class="tag">Have a similar challenge?</span>
                    <h2>LET'S MAKE YOUR NEXT PROJECT <span class="solution-highlight">MEMORABLE.</span></h2>
                    <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn-primary">{t('nav.contact')}</a>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    /* Usando el mismo estilo que la versión en español para consistencia */
    .project-detail-page {
        padding-top: var(--header-height);
    }
    .project-hero {
        padding: 100px 0 60px;
        text-align: center;
    }
    .page-title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: var(--fw-black);
        margin-bottom: 1.5rem;
        line-height: 1.1;
    }
    .project-meta {
        color: var(--text-2);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .hero-image-wrapper {
        margin-top: 60px;
        border-radius: var(--radius-lg);
        overflow: hidden;
        aspect-ratio: 16/8;
    }
    .hero-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .project-content {
        padding: 80px 0 120px;
        line-height: 1.8;
    }
    .prose {
        max-width: 800px;
        margin: 0 auto;
        font-size: 1.15rem;
        color: var(--text-2);
    }
    .prose :global(h2) {
        font-size: 2.2rem;
        color: var(--white);
        margin: 4rem 0 1.5rem;
    }
    .prose :global(h3) {
        font-size: 1.75rem;
        color: var(--white);
        margin: 3rem 0 1rem;
    }
    .prose :global(p) {
        margin-bottom: 2rem;
    }
    .prose :global(ul) {
        margin-bottom: 2rem;
        padding-left: 1.5rem;
    }
    .prose :global(li) {
        margin-bottom: 0.8rem;
    }
    .prose :global(blockquote) {
        border-left: 4px solid var(--accent);
        padding-left: 2rem;
        margin: 4rem 0;
        font-style: italic;
        font-size: 1.5rem;
        color: var(--white);
        background: rgba(255,255,255,0.03);
        padding: 3rem;
        border-radius: 0 20px 20px 0;
    }
    .cta-section {
        padding-bottom: 150px;
    }
</style>
