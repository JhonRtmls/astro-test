---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/pages/inner.css";
import "../../styles/pages/contact.css";
import pinguino from "../../assets/img/pinguino.svg";

const currentLang = Astro.currentLocale || 'es';
---

<Layout 
  title={currentLang === 'es' ? "Gestoo | Contacto" : "Gestoo | Contact"}
  keywords="contacto gestoo, cotizar eventos patagonia, servicios branding chile, oficina punta arenas, presupuesto producción técnica"
>
  <Navbar />
  <img src={pinguino.src} alt="" class="bg-asset asset-pinguino" />
  <main id="main-content">
    <section class="section contact-section">
      <div class="container content-contained">
        <div class="contact-grid">
          <div class="contact-info-column reveal">
            <span class="tag">{currentLang === 'es' ? 'Contacto' : 'Contact'}</span>
            <h1 class="page-title" style="margin-bottom: 2rem">
              {currentLang === 'es' ? 'Expertos en soluciones' : 'Experts in'} <br /><span class="gradient-text">{currentLang === 'es' ? 'MICE y B2B.' : 'MICE & B2B solutions.'}</span>
            </h1>
            <p class="contact-description">
              {currentLang === 'es' 
                ? 'Desde la Patagonia para todo Chile, transformamos la complejidad en experiencias memorables. Cuéntanos qué tienes en mente.'
                : 'From Patagonia to all of Chile, we transform complexity into memorable experiences. Tell us what you have in mind.'}
            </p>

            <div class="contact-methods">
              <div class="method-item">
                <div class="method-icon"><img src="/astro-test/img/contacto_icons/location.svg" alt="Ubicación" /></div>
                <div class="method-text">
                  <label>{currentLang === 'es' ? 'Ubicación' : 'Location'}</label>
                  <p>Av. Independencia 313, <br />Punta Arenas, Magallanes, Chile</p>
                </div>
              </div>
              <div class="method-item">
                <div class="method-icon"><img src="/astro-test/img/contacto_icons/mail.svg" alt="Email" /></div>
                <div class="method-text">
                  <label>{currentLang === 'es' ? 'Email Corporativo' : 'Corporate Email'}</label>
                  <a href="#" class="email-link" data-name="contacto" data-domain="gestoo.cl">Cargando email...</a>
                </div>
              </div>
            </div>
          </div>

          <div class="contact-form-column reveal">
            <form class="premium-form" id="contactForm">
              <div class="form-row">
                <div class="form-group">
                  <label>{currentLang === 'es' ? 'Nombre Completo *' : 'Full Name *'}</label>
                  <input type="text" name="name" placeholder={currentLang === 'es' ? "Ej: Juan Pérez" : "e.g. John Doe"} required />
                </div>
                <div class="form-group">
                  <label>{currentLang === 'es' ? 'Empresa / Institución' : 'Company / Institution'}</label>
                  <input type="text" name="company" placeholder={currentLang === 'es' ? "Nombre de tu organización" : "Your organization"} />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>{currentLang === 'es' ? 'Email Corporativo *' : 'Corporate Email *'}</label>
                  <input type="email" name="email" placeholder="email@ejemplo.com" required />
                </div>
                <div class="form-group">
                  <label>{currentLang === 'es' ? 'Teléfono de Contacto' : 'Phone Number'}</label>
                  <input type="tel" name="phone" placeholder="+56 9 ..." />
                </div>
              </div>

              <div class="form-group">
                <label>{currentLang === 'es' ? 'Servicio de Interés' : 'Service of Interest'}</label>
                <select name="service">
                  <option value="">{currentLang === 'es' ? 'Selecciona una opción' : 'Select an option'}</option>
                  <option value="branding">{currentLang === 'es' ? 'Branding & Identidad' : 'Branding & Identity'}</option>
                  <option value="mice">{currentLang === 'es' ? 'Turismo MICE' : 'MICE Tourism'}</option>
                  <option value="produccion">{currentLang === 'es' ? 'Producción Técnica' : 'Technical Production'}</option>
                  <option value="logistica">{currentLang === 'es' ? 'Logística Patagonia' : 'Patagonia Logistics'}</option>
                  <option value="otros">{currentLang === 'es' ? 'Otros / No estoy seguro' : 'Others / Not sure'}</option>
                </select>
              </div>

              <div class="form-group">
                <label>{currentLang === 'es' ? 'Mensaje o Requerimiento *' : 'Message or Request *'}</label>
                <textarea name="message" rows="4" placeholder={currentLang === 'es' ? "¿En qué podemos ayudarte?" : "How can we help you?"} required></textarea>
              </div>

              <div class="form-submit">
                <button type="submit" class="btn-orange-glow" id="submitBtn">
                  {currentLang === 'es' ? 'Enviar Requerimiento →' : 'Send Request →'}
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    // Email Obfuscation
    document.addEventListener('astro:page-load', () => {
        const emailLink = document.querySelector('.email-link');
        if (emailLink) {
            const user = emailLink.getAttribute('data-name');
            const domain = emailLink.getAttribute('data-domain');
            const fullEmail = `${user}@${domain}`;
            emailLink.href = `mailto:${fullEmail}`;
            emailLink.textContent = fullEmail;
        }

        const contactForm = document.getElementById("contactForm");
        if (contactForm) {
          contactForm.addEventListener("submit", function (e) {
            e.preventDefault();
            const btn = document.getElementById("submitBtn");
            const originalText = btn.textContent;
            btn.textContent = "Enviando...";
            btn.disabled = true;
            
            // Simulación de envío
            setTimeout(() => {
              alert("Gracias. Hemos recibido tu requerimiento y te contactaremos a la brevedad.");
              btn.textContent = originalText;
              btn.disabled = false;
              contactForm.reset();
            }, 1500);
          });
        }
    });
  </script>
</Layout>
