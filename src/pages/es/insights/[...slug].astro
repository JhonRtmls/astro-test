---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import '../../../styles/pages/inner.css';

export async function getStaticPaths() {
    const posts = await getCollection('posts');
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;

// Metadata dinámica
const title = `${post.data.title} | Insights | Gestoo`;
const description = post.data.description;
---

<Layout title={title} description={description}>
    <Navbar />

    <main>
        <article class="post-full">
            <header class="post-header">
                <div class="container content-contained">
                    <div class="reveal">
                        <span class="post-meta">{post.data.category} • {post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                        <h1 class="post-title">{post.data.title}</h1>
                        <p class="post-excerpt">{post.data.description}</p>
                        <div class="post-author">
                            <span>Por <strong>{post.data.author}</strong></span>
                        </div>
                    </div>
                </div>
            </header>

            <div class="post-hero-image reveal">
                <img src={post.data.heroImage ? (post.data.heroImage.startsWith('/') ? `${base}${post.data.heroImage}` : post.data.heroImage) : `${base}/img/news-default.jpg`} alt={post.data.title} />
            </div>

            <section class="post-content-wrap">
                <div class="container content-narrow reveal">
                    <div class="post-body">
                        <Content />
                    </div>
                    
                    <div class="post-footer">
                        <div class="post-tags">
                            {post.data.tags?.map(tag => (
                                <span class="tag-pill">{tag}</span>
                            ))}
                        </div>
                        <div class="post-share">
                            <a href={`${base}/insights`} class="back-link">← Volver a Insights</a>
                        </div>
                    </div>
                </div>
            </section>
        </article>
    </main>

    <Footer />
</Layout>

<style>
    .post-header {
        padding: 120px 0 60px;
        text-align: center;
    }

    .post-meta {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
        font-weight: var(--fw-bold);
        display: block;
        margin-bottom: 1.5rem;
    }

    .post-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        line-height: 1.1;
        margin-bottom: 2rem;
        color: var(--white);
    }

    .post-excerpt {
        font-size: 1.25rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.6);
        max-width: 800px;
        margin: 0 auto 2.5rem;
    }

    .post-author {
        font-size: 0.9rem;
        color: var(--white);
    }

    .post-hero-image {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        height: 60vh;
        border-radius: 4px;
        overflow: hidden;
    }

    .post-hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .post-content-wrap {
        padding: 80px 0;
    }

    .content-narrow {
        max-width: 800px;
        margin: 0 auto;
    }

    .post-body {
        font-size: 1.15rem;
        line-height: 1.8;
        color: rgba(255,255,255,0.8);
    }

    .post-body :global(h2), .post-body :global(h3) {
        color: var(--white);
        margin: 3rem 0 1.5rem;
    }

    .post-body :global(p) {
        margin-bottom: 1.5rem;
    }

    .post-body :global(ul) {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }

    .post-body :global(li) {
        margin-bottom: 0.5rem;
    }

    .post-footer {
        margin-top: 5rem;
        padding-top: 3rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 2rem;
    }

    .tag-pill {
        display: inline-block;
        padding: 0.4rem 1rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 100px;
        font-size: 0.8rem;
        margin-right: 0.5rem;
        color: rgba(255,255,255,0.6);
    }

    .back-link {
        color: var(--accent);
        text-decoration: none;
        font-weight: var(--fw-bold);
        font-size: 0.9rem;
    }

    @media (max-width: 768px) {
        .post-hero-image {
            height: 40vh;
            border-radius: 0;
        }
    }
</style>
