---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;
---

<Layout title={`${project.data.title} | Gestoo`}>
    <Navbar />
    <main class="project-detail-page">
        <header class="project-hero">
            <div class="container content-contained">
                <span class="tag">{project.data.category}</span>
                <h1 class="page-title">{project.data.title}</h1>
                <p class="project-meta">Publicado el {project.data.pubDate.toLocaleDateString()}</p>
            </div>
            {project.data.heroImage && (
                <div class="hero-image-wrapper">
                    <img 
                        src={project.data.heroImage.startsWith('/') ? `${base}${project.data.heroImage}` : project.data.heroImage} 
                        alt={project.data.title} 
                    />
                </div>
            )}
        </header>

        <section class="project-content">
            <div class="container content-contained prose">
                <Content />
            </div>
        </section>
        
        <section class="cta-section">
            <div class="container content-contained">
                <div class="solution-card">
                    <span class="tag">¿Tienes un desafío similar?</span>
                    <h2>HAGAMOS QUE TU PRÓXIMO PROYECTO SEA <span class="solution-highlight">MEMORABLE.</span></h2>
                    <a href="/astro-test/contact" class="btn-primary">HABLEMOS</a>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .project-detail-page {
        padding-top: var(--header-height);
    }
    .project-hero {
        padding: 80px 0;
        text-align: center;
    }
    .page-title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: var(--fw-black);
        margin-bottom: 1.5rem;
    }
    .project-meta {
        color: var(--text-2);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .hero-image-wrapper {
        margin-top: 60px;
        width: 100%;
        max-width: 1200px;
        margin-inline: auto;
        border-radius: var(--radius-lg);
        overflow: hidden;
        aspect-ratio: 16/7;
    }
    .hero-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .project-content {
        padding: 100px 0;
        line-height: 1.8;
    }
    /* Estilos básicos de prosa (puedes expandirlos) */
    .prose {
        max-width: 800px;
        margin: 0 auto;
        font-size: 1.15rem;
        color: var(--text-2);
    }
    .prose :global(h2) {
        font-size: 2.2rem;
        color: var(--white);
        margin: 3rem 0 1.5rem;
    }
    .prose :global(p) {
        margin-bottom: 2rem;
    }
    .prose :global(ul) {
        margin-bottom: 2rem;
        padding-left: 1.5rem;
    }
    .prose :global(li) {
        margin-bottom: 0.5rem;
    }
    .prose :global(blockquote) {
        border-left: 4px solid var(--accent-2);
        padding-left: 2rem;
        margin: 4rem 0;
        font-style: italic;
        font-size: 1.5rem;
        color: var(--white);
    }
    .cta-section {
        padding-bottom: 150px;
    }
</style>
