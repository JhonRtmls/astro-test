---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import "../styles/pages/inner.css";
import "../styles/pages/works.css";
const base = import.meta.env.BASE_URL;

const projects = await getCollection("projects");

// Extraer categorías únicas de los proyectos MDX
const allCategories = [...new Set(projects.map((p) => p.data.category))];
const categories = allCategories.slice(0, 6); // Limitamos a 6 como pediste
---

<Layout title="Gestoo | Proyectos">
  <Navbar />
  <img src={`${base}/img/brujula-sur.svg`} alt="Ilustración de brújula apuntando al sur - Casos de éxito Gestoo" class="bg-illustration" />
  <main>
    <section class="page-hero">
      <div class="container page-hero-content">
        <div class="reveal">
          <span class="tag" data-i18n="works-tag">Casos de Éxito</span>
          <h1 class="page-title" data-i18n="works-hero-title">
            Experiencias que hablan <span class="gradient-text"
              >por nosotros.</span>
          </h1>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="section">
      <div class="container">
        <div class="section-header reveal">
          <span class="tag" data-i18n="works-tag">Portfolio</span>
          <h2 class="section-title" data-i18n="works-title">
            Nuestra <em>selección.</em>
          </h2>
        </div>

        <div class="filter-bar reveal" id="filterBar">
          <button
            class="filter-btn active"
            data-filter="all"
            data-i18n="works-filter-all">Todos</button
          >
          {categories.map((cat) => (
            <button 
              class="filter-btn" 
              data-filter={cat} 
              data-i18n={`tag-${cat.toLowerCase().replace(' & ', '-').replace(' ', '-')}`}
            >{cat}</button>
          ))}
        </div>

        <div class="portfolio-grid" id="portfolioGrid">
            {projects.map((project) => (
                <a href={`${base}/projects/${project.id}`} class="portfolio-card reveal" data-category={project.data.category}>
                    <div class="portfolio-thumb">
                        <img 
                            src={project.data.heroImage ? (project.data.heroImage.startsWith('/') ? `${base}${project.data.heroImage}` : project.data.heroImage) : `${base}/img/work-default.jpg`} 
                            alt={project.data.title} 
                            loading="lazy" 
                            style="width:100%; height:100%; object-fit:cover; display:block;"
                        />
                    </div>
                    <div class="portfolio-info">
                        <span class="work-cat" data-i18n={`tag-${project.data.category.toLowerCase().replace(' & ', '-').replace(' ', '-')}`}>{project.data.category}</span>
                        <h3>{project.data.title}</h3>
                        <p>{project.data.description}</p>
                    </div>
                </a>
            ))}
        </div>
      </div>
    </section>

    <section class="section solution-section">
      <div class="container content-contained">
        <div class="solution-card reveal">
          <span class="tag" data-i18n="services-tag">Problem Solvers</span>
          <h2 class="cta-title" data-i18n="services-cta-title">
            ¿Tienes un desafío? <br /> Somos la <span class="solution-highlight"
              >solución.</span>
          </h2>
          <p data-i18n="services-cta-desc">
            Optimizamos procesos, elevamos tu marca y garantizamos que cada
            evento sea una inversión, no un gasto. Tu éxito es nuestra métrica.
          </p>
          <a
            href={`${base}/contact`}
            class="btn-orange-glow"
            data-i18n="about-cta-btn">Cotiza tu solución ahora →</a
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    // Script simple para el filtrado visual
    document.addEventListener("astro:page-load", () => {
        const filterBtns = document.querySelectorAll(".filter-btn");
        const cards = document.querySelectorAll(".portfolio-card");

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const filter = btn.dataset.filter;
                
                filterBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                cards.forEach((card) => {
                    if (filter === "all" || card.dataset.category === filter) {
                        card.style.display = "flex";
                    } else {
                        card.style.display = "none";
                    }
                });
            });
        });
    });
  </script>
</Layout>
