---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/pages/inner.css";
import "../styles/pages/works.css";
const base = import.meta.env.BASE_URL;
---

<Layout title="Gestoo | Proyectos">
  <Navbar />
  <img src={`${base}/img/brujula-sur.svg`} alt="" class="bg-illustration" />
  <main>
    <section class="page-hero">
      <div class="container page-hero-content">
        <div class="reveal">
          <span class="tag" data-i18n="works-tag">Casos de Éxito</span>
          <h1 class="page-title" data-i18n="works-hero-title">
            Experiencias que hablan <span class="gradient-text"
              >por nosotros.</span>
          </h1>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="section">
      <div class="container">
        <div class="section-header reveal">
          <span class="tag" data-i18n="works-tag">Portfolio</span>
          <h2 class="section-title" data-i18n="works-title">
            Nuestra <em>selección.</em>
          </h2>
        </div>

        <div class="filter-bar reveal" id="filterBar">
          <button
            class="filter-btn active"
            data-filter="all"
            data-i18n="works-filter-all">Todos</button
          >
          <button
            class="filter-btn"
            data-filter="corporativo"
            data-i18n="works-filter-corp">Corporativo</button
          >
          <button
            class="filter-btn"
            data-filter="social"
            data-i18n="works-filter-social">Social</button
          >
          <button
            class="filter-btn"
            data-filter="show"
            data-i18n="works-filter-show">Show & Cultura</button
          >
        </div>

        <div class="portfolio-grid" id="portfolioGrid"></div>
      </div>
    </section>

    <section class="section solution-section">
      <div class="container content-contained">
        <div class="solution-card reveal">
          <span class="tag" data-i18n="services-tag">Problem Solvers</span>
          <h2 class="cta-title" data-i18n="services-cta-title">
            ¿Tienes un desafío? <br /> Somos la <span class="solution-highlight"
              >solución.</span>
          </h2>
          <p data-i18n="services-cta-desc">
            Optimizamos procesos, elevamos tu marca y garantizamos que cada
            evento sea una inversión, no un gasto. Tu éxito es nuestra métrica.
          </p>
          <a
            href={`${base}/contact`}
            class="btn-orange-glow"
            data-i18n="about-cta-btn">Cotiza tu solución ahora →</a
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline src={`${import.meta.env.BASE_URL}/js/data/projects.js`}
  ></script>
  <script is:inline define:vars={{ base }}>
    const grid = document.getElementById("portfolioGrid");

    function renderProjects(filter = "all") {
      if (!grid || typeof projectsData === "undefined") return;
      grid.innerHTML = "";
      const filtered =
        filter === "all"
          ? projectsData
          : projectsData.filter((p) => p.category === filter);

      filtered.forEach((project) => {
        const card = document.createElement("a");
        card.href = `${base}works/${project.id}`;
        card.className = "portfolio-card reveal";
        card.dataset.category = project.category;
        card.innerHTML = `
                    <div class="portfolio-thumb">
                        <div class="portfolio-thumb-bg">
                            <img src="${project.image.replace("../", base + "/")}" alt="${project.title}" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
                        </div>
                    </div>
                    <div class="portfolio-info">
                        <span class="work-cat">${project.tag}</span>
                        <h3>${project.title}</h3>
                        <p>${project.description}</p>
                    </div>
                `;
        grid.appendChild(card);
      });

      const newCards = grid.querySelectorAll(".reveal");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      newCards.forEach((c) => observer.observe(c));
    }

    if (typeof projectsData !== "undefined") {
      renderProjects();
    }

    const filterBtns = document.querySelectorAll(".filter-btn");
    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        filterBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        renderProjects(btn.dataset.filter);
      });
    });
  </script>
</Layout>
